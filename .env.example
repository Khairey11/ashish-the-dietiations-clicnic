# ============================================================
# The Dietitian's Clinic — environment variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.

# ----- Database -----
# SQLite for dev. Production should use PostgreSQL, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?schema=public"
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ----- App URL -----
# Public base URL of the deployment. Used for password-reset email links,
# payment gateway return URLs, sitemap, email verification links, etc.
# NO trailing slash.
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Auth -----
# HMAC secret used to sign the admin_session cookie. MUST be at least 32 chars
# in production. Generate one with: `openssl rand -hex 32`
ADMIN_SESSION_SECRET=""

# ----- Webhook (auto-deploy) -----
# GitHub webhook secret. MUST be at least 16 chars. NO default is shipped —
# if unset, /api/webhook returns 503.
WEBHOOK_SECRET=""

# ----- Email (Resend) -----
# Get an API key at https://resend.com
RESEND_API_KEY=""
FROM_EMAIL="care@thedietitiansclinic.health"

# ----- Sentry (error tracking) -----
# Get a DSN at https://sentry.io — both vars should be the same DSN value.
# If unset, Sentry is a no-op (SDK loads but doesn't transmit).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Only needed for source-map upload in CI/prod builds:
SENTRY_AUTH_TOKEN=""

# ----- Payment: Khalti -----
# Get credentials at https://dashboard.khalti.com
KHALTI_API_KEY=""
KHALTI_SECRET=""
# "test" or "production"
KHALTI_ENV="test"

# ----- Payment: eSewa -----
# Get credentials at https://esewa.com.np/merchant
ESEWA_MERCHANT_CODE=""
# "test" or "production"
ESEWA_ENV="test"

# ----- Seed scripts (only needed when running `bun run db:seed`) -----
# All three are required for the seed to run. Each must be >= 10 chars.
SEED_ADMIN_PASSWORD=""
SEED_CLIENT_PASSWORD=""
SEED_DIETITIAN_PASSWORD=""
