// The Dietitian's Clinic — Prisma schema
// Database models for The Dietitian's Clinic
// SQLite is used for development; production should switch to PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  DIETITIAN
  NUTRITIONIST
  RECEPTIONIST
  MANAGER
  CONTENT_MANAGER
  FINANCE
  CLIENT
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  phone         String?
  role          UserRole @default(CLIENT)
  avatarUrl     String?
  emailVerified DateTime?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  patient           Patient?
  dietitian         Dietitian?
  appointments      Appointment[]      @relation("ClientAppointments")
  leads             Lead[]
  messagesSent      Message[]          @relation("MessageSender")
  messagesReceived  Message[]          @relation("MessageRecipient")
  notifications     Notification[]
  payments          Payment[]
  activityLogs      ActivityLog[]
  auditLogs         AuditLog[]
  blogPosts         BlogPost[]
  testimonials      Testimonial[]
  passwordResets    PasswordReset[]
  sessions          Session[]
  accounts          Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// CLINICAL PROFILES
// ============================================================

model Dietitian {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String
  credentials   String
  specialty     String
  bio           String
  experience    Int
  languages     String   // JSON-serialised array (SQLite has no native array)
  rating        Float    @default(0)
  reviewsCount  Int      @default(0)
  avatarUrl     String?
  initials      String
  accent        String
  availability  String
  focus         String   // JSON-serialised array
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  mealPlans    MealPlan[]
  patients     Patient[]
}

model Patient {
  id              String   @id @default(cuid())
  userId          String   @unique
  dietitianId     String?
  dateOfBirth     DateTime?
  gender          String?
  height          Float?
  startingWeight  Float?
  currentWeight   Float?
  targetWeight    Float?
  bodyFatPct      Float?
  medicalHistory  String?
  allergies       String?
  medications     String?
  primaryGoal     String?
  condition       String?
  programId       String?
  startDate       DateTime?
  emergencyName   String?
  emergencyPhone  String?
  address         String?
  city            String?
  country          String?
  onboardingCompleted  Boolean  @default(false)
  dietaryPreferences   String?
  activityLevel        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietitian      Dietitian?    @relation(fields: [dietitianId], references: [id], onDelete: SetNull)
  program        Program?      @relation(fields: [programId], references: [id], onDelete: SetNull)
  appointments   Appointment[]
  measurements   Measurement[]
  progressPhotos ProgressPhoto[]
  reports        Report[]
  mealPlans      MealPlan[]
  documents      Document[]

  @@index([dietitianId])
  @@index([programId])
}

// ============================================================
// SERVICES & PROGRAMS
// ============================================================

enum ServiceCategory {
  WEIGHT
  MEDICAL
  LIFE_STAGE
  PERFORMANCE
  CORPORATE
}

model Service {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  tagline     String
  problem     String
  solution    String
  benefits    String          // JSON-serialised array
  duration    String
  accent      String
  category    ServiceCategory
  iconName    String
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  appointments Appointment[]
  faqs         FAQ[]
}

model Program {
  id            String   @id @default(cuid())
  slug          String   @unique
  duration      String
  days          Int
  price         Float
  originalPrice Float
  tagline       String
  features      String   // JSON-serialised array
  support       String   // JSON-serialised array
  accent        String
  isPopular     Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments Appointment[]
  patients     Patient[]
  payments     Payment[]
}

// ============================================================
// APPOINTMENTS
// ============================================================

enum AppointmentStatus {
  PENDING
  CONFIRMED
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentMode {
  VIDEO
  IN_CLINIC
  PHONE
}

model Appointment {
  id            String            @id @default(cuid())
  clientId      String
  patientId     String?
  dietitianId   String
  serviceId     String?
  programId     String?
  scheduledAt   DateTime
  durationMin   Int               @default(60)
  mode          AppointmentMode   @default(VIDEO)
  status        AppointmentStatus @default(PENDING)
  meetingLink   String?
  notes         String?
  reason        String?
  isRecurring   Boolean           @default(false)
  parentApptId  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  client     User       @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Restrict)
  patient    Patient?   @relation(fields: [patientId], references: [id], onDelete: SetNull)
  dietitian  Dietitian  @relation(fields: [dietitianId], references: [id], onDelete: Restrict)
  service    Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  program    Program?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  reminders  Reminder[]
  feedback   AppointmentFeedback?

  @@index([clientId])
  @@index([patientId])
  @@index([dietitianId])
  @@index([serviceId])
  @@index([programId])
  @@index([scheduledAt])
  @@index([status])
}

model AppointmentFeedback {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  rating        Int
  comments      String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Reminder {
  id            String   @id @default(cuid())
  appointmentId String
  type          String   // EMAIL, SMS, WHATSAPP, PUSH
  scheduledFor  DateTime
  sentAt        DateTime?
  status        String   @default("PENDING")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

// ============================================================
// LEAD MANAGEMENT
// ============================================================

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  PHONE
  REFERRAL
  SOCIAL
  AD
  ORGANIC
  DIRECT
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String?
  service     String?
  source      LeadSource @default(WEBSITE)
  status      LeadStatus @default(NEW)
  assignedTo  String?
  notes       String?
  followUpAt  DateTime?
  convertedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assignedUser User? @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

// ============================================================
// DIET PLANS & MEALS
// ============================================================

model MealPlan {
  id          String   @id @default(cuid())
  patientId   String
  dietitianId String
  title       String
  description String?
  totalCalories Int?
  proteinG    Float?
  carbsG      Float?
  fatG        Float?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dietitian Dietitian @relation(fields: [dietitianId], references: [id], onDelete: Restrict)
  items    MealItem[]

  @@index([patientId])
  @@index([dietitianId])
  @@index([isActive])
}

model MealItem {
  id          String   @id @default(cuid())
  mealPlanId  String
  meal        String   // BREAKFAST, LUNCH, DINNER, SNACK
  name        String
  calories    Int
  proteinG    Float?
  carbsG      Float?
  fatG        Float?
  alternatives String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
}

// ============================================================
// PROGRESS & MEASUREMENTS
// ============================================================

model Measurement {
  id          String   @id @default(cuid())
  patientId   String
  weight      Float?
  height      Float?
  waist       Float?
  hip         Float?
  chest       Float?
  arm         Float?
  thigh       Float?
  bodyFat     Float?
  muscleMass  Float?
  visceralFat Float?
  bmr         Float?
  notes       String?
  measuredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([measuredAt])
}

model ProgressPhoto {
  id          String   @id @default(cuid())
  patientId   String
  frontUrl    String?
  sideUrl     String?
  backUrl     String?
  weekNumber  Int?
  notes       String?
  uploadedAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Report {
  id          String   @id @default(cuid())
  patientId   String
  title       String
  type        String   // LAB, BODY_COMP, PROGRESS, CUSTOM
  fileUrl     String
  summary     String?
  uploadedAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([uploadedAt])
}

model Document {
  id        String   @id @default(cuid())
  patientId String
  name      String
  fileUrl   String
  fileType  String
  size      Int?
  uploadedAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([uploadedAt])
}

// ============================================================
// PAYMENTS & INVOICES
// ============================================================

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_PAID
}

enum PaymentMethod {
  KHALTI
  ESEWA
  STRIPE
  BANK_TRANSFER
  CASH
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  clientId    String
  amount      Float
  tax         Float    @default(0)
  discount    Float    @default(0)
  total       Float
  status      String   @default("PENDING")
  dueDate     DateTime?
  issuedAt    DateTime @default(now())
  paidAt      DateTime?

  payments Payment[]

  @@index([clientId])
}

model Payment {
  id           String         @id @default(cuid())
  invoiceId    String?
  clientId     String
  programId    String?
  amount       Float
  currency     String         @default("NPR")
  method       PaymentMethod
  status       PaymentStatus  @default(PENDING)
  txnId        String?  @unique
  txnRef       String?
  metadata     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  invoice  Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  client   User      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  program  Program?  @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([programId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// COMMUNICATION
// ============================================================

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  subject     String?
  body        String
  isRead      Boolean  @default(false)
  readAt      DateTime?
  sentAt      DateTime @default(now())

  sender    User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  source    String   @default("FOOTER")
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
}

// ============================================================
// CONTENT (BLOG, FAQ, TESTIMONIAL)
// ============================================================

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  createdAt   DateTime   @default(now())

  blogPosts BlogPost[]
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   // Markdown / serialised JSON
  authorId    String?
  categoryId  String?
  tags        String   // JSON-serialised array
  coverAccent String?
  readingTime Int      @default(5)
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  scheduledAt DateTime?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User?     @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
}

model FAQ {
  id         String   @id @default(cuid())
  question   String
  answer     String
  category   String
  serviceId  String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id])
}

model Testimonial {
  id            String   @id @default(cuid())
  clientId      String?
  name          String
  age           Int?
  city          String?
  condition     String
  rating        Int      @default(5)
  beforeWeight  Float?
  afterWeight   Float?
  duration      String?
  quote         String
  highlight     String
  initials      String
  accent        String
  tag           String
  videoUrl      String?
  isApproved    Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())

  client User? @relation(fields: [clientId], references: [id])
}

// ============================================================
// SITE SETTINGS & MEDIA
// ============================================================

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Media {
  id        String   @id @default(cuid())
  name      String
  url       String
  fileType  String
  size      Int?
  altText   String?
  uploadedAt DateTime @default(now())
}

// ============================================================
// AUDIT & ACTIVITY LOGS
// ============================================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  before    String?
  after     String?
  entity    String
  entityId  String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
}
